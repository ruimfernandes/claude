{
    "permissions": {
      "allow": [
        "Bash(elixir /tmp/*.exs)",
        "Bash(elixir /tmp/**/*.exs)",
        "Bash(cat /tmp/*)",
        "Bash(cat /tmp/**/*)",
        "Bash(say *)"
      ],
      "defaultMode": "default"
    },
    "model": "opus[1m]",
    "hooks": {
      "PreToolUse": [
        {
          "matcher": "Bash",
          "hooks": [
            {
              "type": "command",
              "command": "~/.claude/hooks/wrap_bash_silent.sh"
            }
          ]
        }
      ],
      "PostToolUse": [
        {
          "matcher": "Edit|MultiEdit|Write",
          "hooks": [
            {
              "type": "command",
              "command": "jq -r '.tool_input.file_path | select(test(\"\\\\.exs?$\"))' | xargs -I{} mix format \"{}\""
            }
          ]
        }
      ]
    },
    "enabledPlugins": {
    },
    "extraKnownMarketplaces": {},
    "alwaysThinkingEnabled": true,
    "effortLevel": "high",
    "advisorModel": "opus",
    "autoDreamEnabled": true,
    "skipDangerousModePermissionPrompt": true
  }