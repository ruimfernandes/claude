#!/usr/bin/env bash
# Transparent `mix` that runs inside the Elixir dev container.
# `mix format`, `mix test`, `mix deps.get`, ... all "just work".
set -euo pipefail

IMAGE="${BUILDEROS_ELIXIR_IMAGE:-builderos-elixir-dev:latest}"
PROJECT_DIR="${BUILDEROS_PROJECT_DIR:-/home/dev/project}"
DEFAULT_WORKDIR="$PROJECT_DIR/backend"

# Ensure the image exists. If the async background build is still running this
# blocks on its flock until it finishes; otherwise it builds on demand.
builderos-elixir-build || true

# No image (e.g. this project has no backend/Dockerfile.dev): fall back to a
# real host mix if one exists, else fail clearly.
if ! docker image inspect "$IMAGE" >/dev/null 2>&1; then
  for candidate in /usr/local/bin/mix /usr/bin/mix "$HOME/.asdf/shims/mix"; do
    [ -x "$candidate" ] && exec "$candidate" "$@"
  done
  echo "mix: no Elixir dev image ($IMAGE) and no host mix found" >&2
  exit 127
fi

# Run from the current directory when it's inside the project and holds a
# mix.exs; otherwise default to backend/.
host_pwd="$(pwd)"
run_dir="$DEFAULT_WORKDIR"
case "$host_pwd" in
  "$PROJECT_DIR"|"$PROJECT_DIR"/*)
    [ -f "$host_pwd/mix.exs" ] && run_dir="$host_pwd"
    ;;
esac

# Attach a TTY only when we actually have one, so pipes / non-interactive
# runs (CI-style) still behave.
tty_flags="-i"
[ -t 0 ] && [ -t 1 ] && tty_flags="-it"

exec docker run --rm $tty_flags \
  -v "$PROJECT_DIR":"$PROJECT_DIR" \
  -w "$run_dir" \
  "$IMAGE" mix "$@"
