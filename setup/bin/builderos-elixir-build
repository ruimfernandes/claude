#!/usr/bin/env bash
# Build the Elixir dev image from the project's backend/Dockerfile.dev.
# Idempotent and safe to call concurrently: a flock serialises builds, so the
# background (async) build and any on-demand build from the `mix` wrapper never
# race. Callers that hit the lock simply wait for the in-flight build to finish.
set -euo pipefail

PROJECT_DIR="${BUILDEROS_PROJECT_DIR:-/home/dev/project}"
DOCKERFILE="$PROJECT_DIR/backend/Dockerfile.dev"
CONTEXT="$PROJECT_DIR/backend"
IMAGE="${BUILDEROS_ELIXIR_IMAGE:-builderos-elixir-dev:latest}"

STATE_DIR="$HOME/.cache/builderos-elixir"
LOG="$STATE_DIR/build.log"
LOCK="$STATE_DIR/build.lock"
mkdir -p "$STATE_DIR"

log() { echo "[$(date -u +%FT%TZ)] $*" >>"$LOG"; }

# Nothing to do on a project that doesn't ship a dev Dockerfile.
if [ ! -f "$DOCKERFILE" ]; then
  log "no $DOCKERFILE — skipping Elixir image build"
  exit 0
fi

# Serialise builds. If another build holds the lock, block until it releases.
exec 9>"$LOCK"
flock 9

# Already built — done.
if docker image inspect "$IMAGE" >/dev/null 2>&1; then
  exit 0
fi

log "building $IMAGE from $DOCKERFILE"
if docker build -f "$DOCKERFILE" -t "$IMAGE" "$CONTEXT" >>"$LOG" 2>&1; then
  log "build complete: $IMAGE"
else
  log "build FAILED — see $LOG"
  exit 1
fi
